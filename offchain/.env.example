# Provider Configuration

# Option 1: Blockfrost (recommended)
BLOCKFROST_API_KEY=your_blockfrost_api_key_here

# Option 2: Kupmios (alternative)
# KUPO_URL=http://your-kupo-url/
# OGMIOS_URL=ws://your-ogmios-url/

# Wallet configuration (use one of these)
WALLET_SEED_PHRASE=your wallet seed phrase here
# Or use a private key
# WALLET_PRIVATE_KEY=your_wallet_private_key_here

# Optional: Expected wallet address for validation
# WALLET_ADDRESS=addr_test1...

# Optional: Expected wallet balance in ADA for validation
# EXPECTED_BALANCE_ADA=19000

# Optional: Deposit amount in lovelace (default: 10000000)
DEPOSIT_AMOUNT=10000000

# Protocol configuration (update these in Config.ts)
# PROTOCOL_BOOT_TRANSACTION_ID=
# PROTOCOL_BOOT_TRANSACTION_INDEX=0
